@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "家长/学员" as Parent
actor 课程顾问
actor 教务老师
actor 财务人员
actor 校长
actor 系统管理员

package "课程顾问" {
    usecase "线索建档\n(自动/手动)" as UC_Lead
    usecase "线索查重\n(阻断/提醒/归属)" as UC_Dedupe
    usecase "推荐课程" as UC_Recommend
    usecase "处理报名/选课" as UC_Enroll
    usecase "转介绍管理" as UC_Referral
    usecase "处理退费/转班" as UC_Refund
}

package "教务老师" {
    usecase "学期排课\n(冲突检测)" as UC_Schedule
    usecase "调课管理" as UC_Reschedule
    usecase "班级名额管控" as UC_Capacity
    usecase "打卡签到\n(扫码/点名)" as UC_Checkin
    usecase "请假/调课处理" as UC_Leave
    usecase "生成消课报表" as UC_Report
}

package "财务人员" {
    usecase "收费台账管理" as UC_Ledger
    usecase "教师薪资核算" as UC_Salary
    usecase "发票管理" as UC_Invoice
    usecase "第三方支付对账" as UC_Reconciliation
    usecase "欠费预警" as UC_Arrears
    usecase "退费审批\n(多级流程)" as UC_Approval
    usecase "优惠活动配置" as UC_Promotion
}

package "校长" {
    usecase "营收对比分析" as UC_Revenue
    usecase "招生统计分析" as UC_EnrollStats
    usecase "续费率分析" as UC_Renewal
    usecase "满班率分析" as UC_FullClass
    usecase "营销效果分析" as UC_Marketing
    usecase "数据主动预警" as UC_Alerts
}

package "系统管理员" {
    usecase "多校区数据隔离" as UC_Isolation
    usecase "用户权限管理" as UC_Rights
    usecase "操作日志审计" as UC_Audit
    usecase "系统配置维护" as UC_Config
    usecase "历史数据导入" as UC_Import
}

' 外部 Actor 关联
Parent --> UC_Enroll
Parent --> UC_Referral
Parent --> UC_Leave : 请假申请

' 内部 Actor 关联
课程顾问 --> UC_Lead
课程顾问 --> UC_Dedupe
课程顾问 --> UC_Recommend
课程顾问 --> UC_Enroll
课程顾问 --> UC_Referral
课程顾问 --> UC_Refund

教务老师 --> UC_Schedule
教务老师 --> UC_Reschedule
教务老师 --> UC_Capacity
教务老师 --> UC_Checkin
教务老师 --> UC_Leave
教务老师 --> UC_Report

财务人员 --> UC_Ledger
财务人员 --> UC_Salary
财务人员 --> UC_Invoice
财务人员 --> UC_Reconciliation
财务人员 --> UC_Arrears
财务人员 --> UC_Approval
财务人员 --> UC_Promotion

校长 --> UC_Revenue
校长 --> UC_EnrollStats
校长 --> UC_Renewal
校长 --> UC_FullClass
校长 --> UC_Marketing
校长 --> UC_Alerts

系统管理员 --> UC_Isolation
系统管理员 --> UC_Rights
系统管理员 --> UC_Audit
系统管理员 --> UC_Config
系统管理员 --> UC_Import

' 跨涉众依赖关系 (..>)
课程顾问 ..> 财务人员 : 支付对账确认
课程顾问 ..> 教务老师 : 班级名额查询
教务老师 ..> 系统管理员 : 校区数据隔离
教务老师 ..> 课程顾问 : 报名/转班信息同步
财务人员 ..> 系统管理员 : 退费审批流配置
财务人员 ..> 教务老师 : 课消数据获取
校长 ..> 教务老师 : 招生/满班率数据
校长 ..> 课程顾问 : 招生/营收数据
校长 ..> 财务人员 : 营收/欠费数据
系统管理员 ..> 校长 : 经营报表数据支撑

@enduml